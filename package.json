{
  "name": "plataforma-hyperion",
  "version": "0.1.0",
  "private": true,
  "description": "Hyperion platform core with autonomous boundaries for products such as PULSO IRIS and LUMEN.",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "architecture:check": "node scripts/architecture/check-boundaries.mjs",
    "architecture:test": "node --test scripts/architecture/check-boundaries.test.mjs scripts/architecture/check-compose-identities.test.mjs scripts/autonomy/real-flow.test.mjs scripts/ci/n-minus-one-pulso-channel-sql-window.test.mjs scripts/ci/resolve-n-minus-one-capabilities.test.mjs scripts/ci/verify-n-minus-one-upgrade-traffic.test.mjs",
    "autonomy:e2e": "node scripts/autonomy/real-flow.e2e.mjs",
    "autonomy:e2e:local": "pnpm build && pnpm autonomy:e2e",
    "compose:check": "node scripts/architecture/check-compose-identities.mjs",
    "backup:test": "node scripts/ops/run-postgres-backup-tests.mjs",
    "build": "pnpm -r build",
    "check": "pnpm architecture:test && pnpm architecture:check && pnpm compose:check && pnpm lint && pnpm backup:test && pnpm build && pnpm -r test",
    "db:migrate": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/index.js",
    "db:lumen:n1-compat": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/lumen-n-minus-one-compatibility.js",
    "db:seed:demo": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/seed-demo.js",
    "db:seed:demo:clear": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/seed-demo.js --clear",
    "db:seed:lumen-demo": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/seed-lumen-demo.js",
    "db:seed:lumen-demo:clear": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/seed-lumen-demo.js --clear",
    "dev:gateway": "pnpm --filter \"@hyperion/api-gateway...\" build && pnpm --filter @hyperion/api-gateway dev",
    "dev:services": "pnpm --filter \"{services/*}...\" build && pnpm --parallel --filter './services/*' dev",
    "dev:web": "pnpm --filter @hyperion/contracts build && pnpm --filter @hyperion/web-console dev",
    "format": "prettier --write .",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:down:jetstream": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.jetstream.yml down",
    "infra:up": "docker compose -f infra/docker-compose.yml up --build",
    "infra:up:jetstream": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.jetstream.yml up --build",
    "lint": "eslint . && prettier --check .",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.11.11",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.2.2",
    "vitest": "^3.0.8"
  }
}
