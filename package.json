{
  "name": "plataforma-hyperion",
  "version": "0.1.0",
  "private": true,
  "description": "Hyperion federated platform and product cells for NOVA, LUMEN and PULSO IRIS.",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "architecture:check": "node scripts/architecture/check-boundaries.mjs",
    "architecture:test": "node --test scripts/architecture/check-boundaries.test.mjs scripts/architecture/check-compose-identities.test.mjs scripts/autonomy/elevenlabs-agent-realtime-config.test.mjs scripts/autonomy/elevenlabs-sip-trunk-config.test.mjs scripts/autonomy/real-flow.test.mjs scripts/ci/n-minus-one-pulso-channel-sql-window.test.mjs scripts/ci/resolve-n-minus-one-capabilities.test.mjs scripts/ci/verify-n-minus-one-lumen-audio.test.mjs scripts/ci/verify-n-minus-one-upgrade-traffic.test.mjs scripts/ops/tenant-scoped-sql.test.mjs",
    "autonomy:e2e": "node scripts/autonomy/real-flow.e2e.mjs",
    "autonomy:e2e:local": "pnpm build && pnpm autonomy:e2e",
    "compose:check": "node scripts/architecture/check-compose-identities.mjs",
    "contracts:compatibility": "node scripts/releases/check-provider-contract-compatibility.mjs",
    "contracts:registry:check": "node scripts/releases/check-provider-artifact-catalog.mjs",
    "contracts:registry:nova-extraction": "node scripts/releases/check-provider-artifact-catalog.mjs --require-published",
    "contracts:registry:nova-readback": "node scripts/releases/verify-provider-artifact-readback.mjs",
    "coopfuturo:check": "npm --prefix apps/coopfuturo-console run check",
    "backup:test": "node scripts/ops/run-postgres-backup-tests.mjs",
    "build": "pnpm -r build",
    "check": "pnpm architecture:test && pnpm federation:test && pnpm docs:test && pnpm release:test && pnpm architecture:check && pnpm federation:check && pnpm frontend:check && pnpm docs:check && pnpm release:check && pnpm compose:check && pnpm lint && pnpm backup:test && pnpm build && pnpm -r test",
    "ci:cell": "node scripts/ci/run-cell-phase.mjs",
    "db:migrate": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/index.js",
    "db:access:migrate": "pnpm --filter @hyperion/access-migrations build && node packages/access-migrations/dist/index.js",
    "db:access:backup": "bash scripts/ops/access-postgres-backup.sh",
    "db:access:restore": "bash scripts/ops/access-postgres-restore.sh",
    "db:audit:backup": "bash scripts/ops/audit-postgres-backup.sh",
    "db:audit:restore": "bash scripts/ops/audit-postgres-restore.sh",
    "db:platform:migrate": "pnpm --filter @hyperion/platform-migrations build && node packages/platform-migrations/dist/index.js",
    "db:lumen:n1-compat": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/lumen-n-minus-one-compatibility.js",
    "db:lumen:backup": "bash scripts/ops/lumen-postgres-backup.sh",
    "db:lumen:restore": "bash scripts/ops/lumen-postgres-restore.sh",
    "db:seed:demo": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/seed-demo.js",
    "db:seed:demo:clear": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/seed-demo.js --clear",
    "db:seed:lumen-demo": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/seed-lumen-demo.js",
    "db:seed:lumen-demo:clear": "pnpm --filter @hyperion/migrations build && node packages/migrations/dist/seed-lumen-demo.js --clear",
    "db:nova:backup": "bash scripts/ops/nova-postgres-backup.sh",
    "db:nova:restore": "bash scripts/ops/nova-postgres-restore.sh",
    "db:pulso:backup": "bash scripts/ops/pulso-postgres-backup.sh",
    "db:pulso:restore": "bash scripts/ops/pulso-postgres-restore.sh",
    "documents:nova:snapshot": "bash scripts/ops/nova-documents-snapshot.sh export",
    "documents:nova:restore": "bash scripts/ops/nova-documents-snapshot.sh restore",
    "dev:gateway": "pnpm --filter \"@hyperion/api-gateway...\" build && pnpm --filter @hyperion/api-gateway dev",
    "dev:services": "pnpm --filter \"{services/*}...\" build && pnpm --parallel --filter './services/*' dev",
    "dev:web": "pnpm dev:pulso",
    "dev:nova": "pnpm --filter @hyperion/nova-console dev",
    "dev:lumen": "pnpm --filter @hyperion/lumen-console dev",
    "dev:pulso": "pnpm --filter @hyperion/pulso-console dev",
    "dev:platform-admin": "pnpm --filter @hyperion/platform-admin-console dev",
    "docs:check": "node scripts/docs/check-docs.mjs",
    "docs:test": "node --test scripts/docs/check-docs.test.mjs",
    "federation:check": "node scripts/architecture/check-federation-boundaries.mjs",
    "federation:access-channel:acceptance": "node scripts/autonomy/access-channel-projection.e2e.mjs",
    "federation:platform-nova:acceptance": "node scripts/autonomy/platform-nova-acceptance.e2e.mjs",
    "federation:nova:extraction:rehearse": "node scripts/federation/rehearse-nova-repository-extraction.mjs",
    "federation:test:cell": "node scripts/ci/run-cell-federation-tests.mjs",
    "federation:test": "node --test scripts/architecture/check-federation-boundaries.test.mjs scripts/architecture/check-federated-ci.test.mjs scripts/autonomy/access-channel-projection.test.mjs scripts/autonomy/access-fk-contract-parity.test.mjs scripts/autonomy/nova-audit-http.test.mjs scripts/autonomy/nova-smoke.test.mjs scripts/autonomy/platform-nova-acceptance.test.mjs scripts/ci/cell-install-plan.test.mjs scripts/ci/nova-migration-autonomy.test.mjs scripts/ci/resolve-access-channel-impact.test.mjs scripts/ci/resolve-cell-impact.test.mjs scripts/ci/resolve-compose-image-reference.test.mjs scripts/ci/resolve-container-scan-plan.test.mjs scripts/ci/run-cell-federation-tests.test.mjs scripts/ci/run-cell-phase.test.mjs scripts/ci/run-pulso-runtime-integrations.test.mjs scripts/ci/smoke-cell-bff-image.test.mjs scripts/ci/verify-required-cell-result.test.mjs scripts/docker/audit-autonomy.test.mjs scripts/docker/generate-cell-contexts.test.mjs scripts/docker/hostname-edge.test.mjs scripts/docker/nginx-federation.test.mjs scripts/docker/nova-migration-artifacts.test.mjs scripts/docker/nova-standalone-compose.test.mjs scripts/docker/platform-standalone-compose.test.mjs scripts/federation/rehearse-nova-repository-extraction.test.mjs",
    "frontend:check": "node --test scripts/frontend/check-console-boundaries.test.mjs scripts/frontend/bundle-provenance.test.mjs && node scripts/frontend/check-console-boundaries.mjs && node scripts/frontend/check-console-bff-contracts.mjs",
    "format": "prettier --write .",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:down:jetstream": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.jetstream.yml down",
    "infra:up": "pnpm docker:contexts && docker compose -f infra/docker-compose.yml up --build",
    "infra:up:jetstream": "pnpm docker:contexts && docker compose -f infra/docker-compose.yml -f infra/docker-compose.jetstream.yml up --build",
    "lint": "eslint . && prettier --check .",
    "ops:nova:recovery:verify": "node scripts/ops/verify-nova-recovery-evidence.mjs",
    "ops:access:postgres:recovery:drill": "node scripts/ops/run-platform-postgres-recovery-drill.mjs --provider access",
    "ops:access:postgres:recovery:test": "node scripts/ops/run-postgres-backup-tests.mjs --cell access",
    "ops:audit:postgres:recovery:drill": "node scripts/ops/run-platform-postgres-recovery-drill.mjs --provider audit",
    "ops:audit:postgres:recovery:test": "node scripts/ops/run-postgres-backup-tests.mjs --cell audit",
    "ops:platform:postgres:recovery:test": "node scripts/ops/run-postgres-backup-tests.mjs --cell platform",
    "ops:nova:postgres:recovery:drill": "node scripts/ops/run-nova-postgres-recovery-drill.mjs",
    "ops:nova:rollback:verify": "node scripts/ops/verify-nova-rollback.mjs",
    "ops:nova:rollback:test": "node --test scripts/ops/verify-nova-rollback.test.mjs",
    "ops:lumen:postgres:recovery:drill": "node scripts/ops/run-lumen-postgres-recovery-drill.mjs",
    "ops:lumen:postgres:recovery:test": "node scripts/ops/run-postgres-backup-tests.mjs --cell lumen",
    "ops:lumen:rollback:verify": "node scripts/ops/verify-lumen-rollback.mjs",
    "ops:lumen:rollback:test": "node --test scripts/ops/verify-lumen-rollback.test.mjs",
    "ops:pulso:postgres:recovery:drill": "node scripts/ops/run-pulso-postgres-recovery-drill.mjs",
    "ops:pulso:postgres:recovery:test": "node scripts/ops/run-postgres-backup-tests.mjs --cell pulso",
    "ops:pulso:rollback:verify": "node scripts/ops/verify-pulso-rollback.mjs",
    "ops:pulso:rollback:test": "node --test scripts/ops/verify-pulso-rollback.test.mjs",
    "ops:pulso:whatsapp:recovery:drill": "node scripts/ops/run-pulso-whatsapp-recovery-drill.mjs",
    "whatsapp:pulso:snapshot": "bash scripts/ops/pulso-whatsapp-sessions-snapshot.sh export",
    "whatsapp:pulso:restore": "bash scripts/ops/pulso-whatsapp-sessions-snapshot.sh restore",
    "docker:contexts": "node scripts/docker/generate-cell-contexts.mjs",
    "docker:contexts:test": "node --test scripts/docker/audit-autonomy.test.mjs scripts/docker/generate-cell-contexts.test.mjs scripts/docker/hostname-edge.test.mjs scripts/docker/nginx-federation.test.mjs scripts/docker/nova-migration-artifacts.test.mjs scripts/docker/nova-standalone-compose.test.mjs",
    "release:check": "node scripts/releases/run-release-checks.mjs",
    "release:generate": "node scripts/releases/generate-release-manifest.mjs",
    "release:test": "node scripts/releases/run-release-tests.mjs",
    "release:verify-registry-path": "node scripts/releases/verify-registry-publish-path.mjs",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hyperion/frontend-build-provenance": "workspace:*",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.11.11",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.2.2",
    "vitest": "^3.0.8"
  }
}
