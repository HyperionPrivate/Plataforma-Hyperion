{
  "name": "@hyperion/lumen-contracts",
  "version": "1.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdministracionHyperion/Plataforma-Hyperion.git",
    "directory": "packages/lumen-contracts"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @hyperion/platform-contracts build",
    "build": "tsc -p tsconfig.json",
    "pretest": "pnpm --filter @hyperion/platform-contracts build",
    "test": "vitest run",
    "pretypecheck": "pnpm --filter @hyperion/platform-contracts build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hyperion/platform-contracts": "1.1.0",
    "zod": "^3.24.2"
  }
}
