{
  "name": "@hyperion/platform-migrations",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema-manifest": {
      "types": "./dist/schema-manifest.d.ts",
      "import": "./dist/schema-manifest.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "migrate": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pg": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "typescript": "^7.0.2"
  }
}
