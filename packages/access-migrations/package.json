{
  "name": "@hyperion/access-migrations",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema-manifest": {
      "types": "./dist/schema-manifest.d.ts",
      "import": "./dist/schema-manifest.js"
    },
    "./runtime-boundary": {
      "types": "./dist/runtime-boundary.d.ts",
      "import": "./dist/runtime-boundary.js"
    },
    "./role-manifest": {
      "types": "./dist/role-manifest.d.ts",
      "import": "./dist/role-manifest.js"
    }
  },
  "scripts": {
    "bootstrap:database": "node dist/bootstrap-database.js",
    "bootstrap:roles": "node dist/bootstrap-roles.js",
    "build": "tsc -p tsconfig.json",
    "migrate": "node dist/index.js",
    "test": "vitest run",
    "test:fresh-start": "vitest run src/fresh-start.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pg": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.11",
    "typescript": "^5.8.2"
  }
}
