  "ancestryOnly": [
    {
      "path": "packages/contracts/src/nova.ts",
      "lineageTargets": ["packages/nova-contracts/src/index.ts"],
      "headPolicy": "remove-during-adaptation",
      "reason": "The compatibility mirror and provider-owned contract coexist at the cut commit, so a direct rename would collide."
    },
    {
      "path": "packages/config/src/deployment-environment.ts",
      "lineageTargets": ["packages/nova-config/src/index.ts"],
      "headPolicy": "remove-during-adaptation",
      "reason": "NOVA config folds selected platform configuration behavior into a product-owned module."
    },
    {
      "path": "packages/config/src/index.ts",
      "lineageTargets": ["packages/nova-config/src/index.ts"],
      "headPolicy": "remove-during-adaptation",
      "reason": "The source and split package coexist at the cut commit."
    },
    {
      "path": "packages/config/src/secret-placeholders.ts",
      "lineageTargets": ["packages/nova-config/src/index.ts"],
      "headPolicy": "remove-during-adaptation",
      "reason": "NOVA retains only its own secret policy after extraction."
    },
    {
      "path": "packages/durable-events/src/index.ts",
      "lineageTargets": ["packages/nova-durable-events/src/index.ts"],
      "headPolicy": "remove-during-adaptation",
      "reason": "The generic and NOVA event runtimes coexist at the cut commit."
    },
    {
      "path": "packages/service-runtime/src",
      "lineageTargets": ["packages/nova-service-runtime/src"],
      "headPolicy": "remove-during-adaptation",
      "reason": "The product runtime was split from the shared runtime while both paths remain present."
    }
  ],
