{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coopfuturo.local/contracts/events/v1/wa.message.received.json",
  "title": "WaMessageReceivedV1",
  "description": "Planned product event schema. Handler NOT implemented in architecture foundation.",
  "allOf": [
    {
      "$ref": "./_envelope.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "const": "wa.message.received"
        },
        "payload": {
          "type": "object",
          "required": [
            "contact_id",
            "wa_thread_id",
            "message_id",
            "direction"
          ],
          "properties": {
            "contact_id": {
              "type": "string"
            },
            "wa_thread_id": {
              "type": "string"
            },
            "message_id": {
              "type": "string"
            },
            "direction": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}