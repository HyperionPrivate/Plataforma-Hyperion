{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coopfuturo.local/contracts/events/v1/contact.imported.json",
  "title": "ContactImportedV1",
  "description": "Planned product event schema. Handler NOT implemented in architecture foundation.",
  "allOf": [
    {
      "$ref": "./_envelope.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "const": "contact.imported"
        },
        "payload": {
          "type": "object",
          "required": [
            "contact_id",
            "funnel_type",
            "segment_code",
            "phone_e164_hash"
          ],
          "properties": {
            "contact_id": {
              "type": "string"
            },
            "funnel_type": {
              "type": "string",
              "enum": ["renovacion", "reactivacion", "nuevo", "microcredito"]
            },
            "segment_code": {
              "type": "string"
            },
            "phone_e164_hash": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}