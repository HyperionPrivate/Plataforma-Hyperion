              "type": "string"
            },
            "dialer_call_id": {
              "type": "string"
            },
            "technical_status": {
              "type": "string"
            },
            "amd_label": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}