{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coopfuturo.local/contracts/events/v1/lead.qualified.json",
  "title": "LeadQualifiedV1",
  "description": "Lead listo para handoff humano (expediente mínimo cumplido).",
  "allOf": [
    { "$ref": "./_envelope.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "lead.qualified" },
        "payload": {
          "type": "object",
          "required": ["contact_id", "segment", "funnel_state", "priority"],
          "properties": {
            "contact_id": { "type": "string" },
            "segment": {
              "type": "string",
              "enum": ["renovacion", "reactivacion", "nuevo", "microcredito"]
            },
            "funnel_state": { "type": "string" },
            "priority": { "type": "string", "enum": ["immediate", "high", "medium", "low"] },
            "document_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "summary": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
