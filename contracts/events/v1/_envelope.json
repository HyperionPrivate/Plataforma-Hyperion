{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coopfuturo.local/contracts/events/v1/_envelope.json",
  "title": "EventEnvelopeV1",
  "description": "Envelope obligatorio. event_id NO sustituye business_idempotency_key. correlation_id alinea con X-Correlation-ID.",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "occurred_at",
    "producer",
    "tenant_id",
    "correlation_id",
    "business_idempotency_key",
    "data_classification",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID único del mensaje (transporte/dedup técnico)."
    },
    "event_type": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "const": "v1" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "causation_id": { "type": ["string", "null"] },
    "business_idempotency_key": {
      "type": "string",
      "minLength": 1,
      "description": "Clave de idempotencia de negocio; distinta de event_id."
    },
    "data_classification": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted_pii"]
    },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
