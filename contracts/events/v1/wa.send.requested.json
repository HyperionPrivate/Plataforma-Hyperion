{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coopfuturo.local/contracts/events/v1/wa.send.requested.json",
  "title": "WaSendRequestedV1",
  "description": "Planned product event schema. Handler NOT implemented in architecture foundation. First outbound requires to_phone_e164; subsequent may use wa_thread_id.",
  "allOf": [
    {
      "$ref": "./_envelope.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "const": "wa.send.requested"
        },
        "payload": {
          "type": "object",
          "required": [
            "contact_id",
            "template_id"
          ],
          "properties": {
            "contact_id": {
              "type": "string"
            },
            "template_id": {
              "type": "string"
            },
            "wa_thread_id": {
              "type": ["string", "null"]
            },
            "to_phone_e164": {
              "type": ["string", "null"],
              "description": "Required on first send when wa_thread_id is null"
            }
          },
          "additionalProperties": false,
          "anyOf": [
            { "required": ["wa_thread_id"] },
            { "required": ["to_phone_e164"] }
          ]
        }
      }
    }
  ]
}
