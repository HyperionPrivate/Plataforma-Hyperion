{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coopfuturo.local/contracts/events/v1/handoff.created.json",
  "title": "HandoffCreatedV1",
  "description": "Planned product event schema. Handler NOT implemented in architecture foundation.",
  "allOf": [
    {
      "$ref": "./_envelope.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "const": "handoff.created"
        },
        "payload": {
          "type": "object",
          "required": [
            "handoff_id",
            "contact_id",
            "priority"
          ],
          "properties": {
            "handoff_id": {
              "type": "string"
            },
            "contact_id": {
              "type": "string"
            },
            "priority": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}