NODE_ENV=production
# La clase de despliegue es explícita: local|ci admite estos placeholders;
# staging|production siempre los rechaza aunque el proceso tenga CI=true.
HYPERION_ENVIRONMENT=local
SERVICE_VERSION=0.1.0
CORS_ALLOWED_ORIGINS=https://console.hyperion.local
SHUTDOWN_TIMEOUT_MS=65000
# Debe ser mayor que SHUTDOWN_TIMEOUT_MS para permitir el drenaje antes de SIGKILL.
SHUTDOWN_GRACE_PERIOD=75s
# Mantener false salvo detrás de proxies controlados; usar sólo IP/CIDR explícitos.
TRUST_PROXY=false
MIGRATION_LOCK_TIMEOUT_MS=10000
MIGRATION_STATEMENT_TIMEOUT_MS=300000
# Herramientas demo: seleccionar siempre por UUID opaco, nunca por slug/customer name.
PULSO_DEMO_TENANT_ID=
LUMEN_DEMO_TENANT_ID=

POSTGRES_USER=hyperion
POSTGRES_PASSWORD=replace-with-real-secret
POSTGRES_DB=hyperion
DATABASE_URL=postgres://hyperion:replace-with-real-secret@postgres:5432/hyperion
# Migrador heredado del plano neutral compartido (compatibilidad N-1).
PLATFORM_MIGRATOR_DATABASE_URL=

# Las migraciones crean y validan estos roles como NOLOGIN; sólo después el
# bootstrap transaccional activa/rota los LOGIN. Deben ser distintos, tener al
# menos 24 caracteres y usar sólo A-Z, a-z, 0-9, punto, guion, guion bajo o ~.
# Rol compartido heredado; no se usa en el despliegue Access vigente.
ACCESS_DATABASE_PASSWORD=replace-access-db-secret-0001
ACCESS_POSTGRES_DB=hyperion_access
ACCESS_MIGRATOR_DATABASE_PASSWORD=replace-access-migrator-secret-0015
IDENTITY_DATABASE_PASSWORD=replace-identity-db-secret-00016
TENANT_DATABASE_PASSWORD=replace-tenant-db-secret-0000017
ACCESS_MIGRATIONS_IMAGE=hyperion/access-migrations:local
SOFIA_DATABASE_PASSWORD=replace-sofia-db-secret-00002
KNOWLEDGE_DATABASE_PASSWORD=replace-knowledge-db-secret-03
AUDIT_DATABASE_PASSWORD=replace-audit-db-secret-00004
INTEGRATION_DATABASE_PASSWORD=replace-integration-db-secret-5
PULSO_DATABASE_PASSWORD=replace-pulso-db-secret-00006
CHANNEL_DATABASE_PASSWORD=replace-channel-db-secret-0007
# PULSO usa dos ejecuciones separadas: expand se detiene en 008; contract llega
# a 016 y exige el recibo v2 ligado/reciente cuando existe data operacional.
PULSO_DEPLOYMENT_ENVIRONMENT=local
PULSO_MIGRATION_PHASE=expand
PULSO_ACCESS_FK_CONTRACT_RECEIPT=
PULSO_ACCESS_FK_CONTRACT_RECEIPT_SHA256=
PULSO_ACCESS_FK_CONTRACT_DEPLOYMENT_ID=
PULSO_ACCESS_FK_CONTRACT_ACCESS_DATABASE=hyperion_access
PULSO_RELEASE_SOURCE_REVISION=
PULSO_ACCESS_FK_PARTIAL_RECOVERY_CONFIRM=
# Sólo para generar el recibo desde una estación operativa; no copiar estas URL
# dentro de imágenes ni compartir una credencial entre ambas bases.
ACCESS_FK_PARITY_ACCESS_DATABASE_URL=
ACCESS_FK_PARITY_PULSO_DATABASE_URL=
LUMEN_DATABASE_PASSWORD=replace-lumen-db-secret-000008
NOVA_DATABASE_PASSWORD=replace-nova-db-secret-0000009
VOICE_DATABASE_PASSWORD=replace-voice-db-secret-000010
LIWA_DATABASE_PASSWORD=replace-liwa-db-secret-0000011
DOCUMENTS_DATABASE_PASSWORD=replace-documents-db-secret-12
# NOVA comparte temporalmente el clúster, no la base lógica ni el owner.
NOVA_POSTGRES_DB=hyperion_nova
NOVA_MIGRATOR_DATABASE_PASSWORD=replace-nova-migrator-secret-0013
# Audit comparte el clúster únicamente durante la transición; su base, owner,
# migrador, ledger y runtime son provider-owned.
AUDIT_POSTGRES_DB=hyperion_audit
AUDIT_MIGRATOR_DATABASE_PASSWORD=replace-audit-migrator-secret-0014
AUDIT_MIGRATIONS_IMAGE=hyperion/audit-migrations:local

# Credenciales HTTP distintas por vínculo productor→consumidor. Cada valor debe
# tener al menos 24 caracteres seguros y no puede reutilizarse en otro vínculo.
GATEWAY_TO_IDENTITY_TOKEN=replace-gateway-identity-edge-001
NOVA_BFF_TO_ACCESS_TOKEN=replace-nova-bff-access-edge-0041
LUMEN_BFF_TO_ACCESS_TOKEN=replace-lumen-bff-access-edge-0042
PULSO_BFF_TO_ACCESS_TOKEN=replace-pulso-bff-access-edge-0043
PLATFORM_ADMIN_BFF_TO_ACCESS_TOKEN=replace-platform-admin-access-0044
PLATFORM_ADMIN_BFF_TO_IDENTITY_TOKEN=replace-platform-admin-identity-0045
PLATFORM_ADMIN_BFF_TO_TENANT_TOKEN=replace-platform-admin-tenant-0046
PLATFORM_ADMIN_BFF_TO_AUDIT_TOKEN=replace-platform-admin-audit-0047
PLATFORM_ADMIN_OPERATOR_ASSERTION_KEY=replace-platform-admin-assert-0048
NOVA_BFF_TO_NOVA_TOKEN=replace-nova-bff-nova-edge-0045
NOVA_BFF_TO_VOICE_TOKEN=replace-nova-bff-voice-edge-0046
NOVA_BFF_TO_LIWA_TOKEN=replace-nova-bff-liwa-edge-0047
NOVA_BFF_TO_DOCUMENTS_TOKEN=replace-nova-bff-documents-edge-0048
NOVA_OPERATOR_ASSERTION_KEY=replace-nova-operator-assertion-0049
NOVA_PROVIDER_EDGE_TOKEN=replace-nova-provider-edge-token-000001
LUMEN_BFF_TO_LUMEN_TOKEN=replace-lumen-bff-lumen-edge-0050
LUMEN_OPERATOR_ASSERTION_KEY=replace-lumen-operator-assertion-0051
PULSO_BFF_TO_CORE_TOKEN=replace-pulso-bff-core-edge-0052
PULSO_BFF_TO_INTEGRATION_TOKEN=replace-pulso-bff-integration-0053
PULSO_OPERATOR_ASSERTION_KEY=replace-pulso-operator-assertion-0054
GATEWAY_TO_INTEGRATION_TOKEN=replace-gateway-integration-edge-002
GATEWAY_TO_PULSO_TOKEN=replace-gateway-pulso-edge-001
GATEWAY_TO_LUMEN_TOKEN=replace-gateway-lumen-edge-002
GATEWAY_TO_NOVA_TOKEN=replace-gateway-nova-edge-000021
GATEWAY_TO_VOICE_TOKEN=replace-gateway-voice-edge-00022
GATEWAY_TO_LIWA_TOKEN=replace-gateway-liwa-edge-000023
GATEWAY_TO_DOCUMENTS_TOKEN=replace-gateway-documents-edge-24
GATEWAY_TO_TENANT_TOKEN=replace-gateway-tenant-edge-016
GATEWAY_TO_AUDIT_TOKEN=replace-gateway-audit-edge-017
GATEWAY_TO_KNOWLEDGE_TOKEN=replace-gateway-knowledge-edge-018
GATEWAY_TO_SOFIA_TOKEN=replace-gateway-sofia-edge-019
# HMAC shared by gateway and receivers that trust operator claims. Distinct from edge tokens.
GATEWAY_OPERATOR_ASSERTION_KEY=replace-gateway-operator-assert-020

# Access firma JWT RS256 breves. Montar la clave privada como secret; nunca
# incluirla en esta plantilla ni en una imagen. Durante rotación, el archivo
# JWKS anterior contiene exclusivamente claves públicas y se retira tras N-1.
ACCESS_TOKEN_PRIVATE_KEY_FILE=
ACCESS_TOKEN_PREVIOUS_JWKS_FILE=
ACCESS_TOKEN_ISSUER=https://access.hyperion.local
ACCESS_TOKEN_AUDIENCES=nova-bff,lumen-bff,pulso-bff,platform-admin-bff
ACCESS_TOKEN_KEY_ID=access-2026-01
ACCESS_TOKEN_TTL_SECONDS=300
ACCESS_JWKS_URL=http://identity-service:8081/.well-known/jwks.json
# En local, BFF y Access comparten una red Docker controlada. Staging/production
# deben usar el JWKS HTTPS público y fijar ACCESS_JWKS_ALLOW_PRIVATE_HTTP=false.
ACCESS_JWKS_ALLOW_PRIVATE_HTTP=true
INTEGRATION_TO_CHANNEL_TOKEN=replace-integration-channel-003
INTEGRATION_TO_SOFIA_TOKEN=replace-integration-sofia-edge-004
INTEGRATION_TO_PULSO_TOKEN=replace-integration-pulso-owner-027
CHANNEL_TO_PULSO_TOKEN=replace-channel-pulso-edge-005
PULSO_TO_CHANNEL_TOKEN=replace-pulso-channel-lookup-016
CHANNEL_TO_AUDIT_TOKEN=replace-channel-audit-edge-006
ACCESS_TO_CHANNEL_TOKEN=replace-access-channel-edge-000006
ACCESS_TO_PULSO_TOKEN=replace-access-pulso-edge-000026
ACCESS_TO_SOFIA_TOKEN=replace-access-sofia-edge-000027
ACCESS_TO_INTEGRATION_TOKEN=replace-access-integration-edge-000028
ACCESS_TO_KNOWLEDGE_TOKEN=replace-access-knowledge-edge-000029
PULSO_TO_SOFIA_TOKEN=replace-pulso-sofia-edge-007
PULSO_TO_AUDIT_TOKEN=replace-pulso-audit-edge-008
PULSO_TO_LUMEN_TOKEN=replace-pulso-lumen-edge-009
SOFIA_TO_CHANNEL_TOKEN=replace-sofia-channel-edge-010
SOFIA_TO_PROMPT_FLOW_TOKEN=replace-sofia-prompt-flow-011
SOFIA_TO_PULSO_TOKEN=replace-sofia-pulso-edge-012
SOFIA_TO_AUDIT_TOKEN=replace-sofia-audit-edge-013
LUMEN_TO_AUDIT_TOKEN=replace-lumen-audit-edge-014
ACCESS_TO_LUMEN_TOKEN=replace-access-lumen-edge-015
ACCESS_TO_NOVA_TOKEN=replace-access-nova-edge-000025
NOVA_TO_AUDIT_TOKEN=replace-nova-audit-edge-000026
NOVA_TO_VOICE_TOKEN=replace-nova-voice-edge-000027
NOVA_TO_LIWA_TOKEN=replace-nova-liwa-edge-0000028
NOVA_TO_DOCUMENTS_TOKEN=replace-nova-documents-edge-29
VOICE_TO_AUDIT_TOKEN=replace-voice-audit-edge-000030
VOICE_TO_DIALER_TOKEN=replace-voice-dialer-edge-00031
VOICE_TO_NOVA_TOKEN=replace-voice-nova-edge-0000032
LIWA_TO_AUDIT_TOKEN=replace-liwa-audit-edge-000033
LIWA_TO_NOVA_TOKEN=replace-liwa-nova-edge-0000034
DOCUMENTS_TO_AUDIT_TOKEN=replace-documents-audit-edge-35
DOCUMENTS_TO_NOVA_TOKEN=replace-documents-nova-edge-36
LIWA_WEBHOOK_SECRET=replace-liwa-webhook-secret-0037
# LIWA must send this value as X-LIWA-WEBHOOK-SECRET. Never place secrets in URLs.
DIALER_WEBHOOK_HMAC_SECRET=replace-dialer-webhook-hmac-38
# voice-channel: default dialer; leave DIALER_* empty outside the dialer overlay
# so UnconfiguredDialer boots the stack. Overlay sets live credentials.
VOICE_MODE=dialer
# Compose network URL when dialer overlay is up. Leave empty to boot UnconfiguredDialer.
DIALER_BASE_URL=http://neutral-dialer:8080
DIALER_ADMIN_USER=admin
DIALER_ADMIN_PASSWORD=
DIALER_DEMO_API_KEY=
# ElevenLabs phone number id (DDI). Required for live outbound; leave empty until provisioned.
DEMO_DDI_PHONE_NUMBER_ID=
# VoipCentral SIP trunk (local only — never commit real password).
# Import smoke DDI: node scripts/autonomy/elevenlabs-import-sip-ddi.mjs --write-env
SIP_TRUNK_ADDRESS=sip.voipcentral.net
SIP_TRUNK_USERNAME=
SIP_TRUNK_PASSWORD=
SIP_TRUNK_TRANSPORT=tcp
SIP_SMOKE_DDI_E164=
# Comma-separated E.164 list for batch import after smoke succeeds
SIP_DDI_E164_LIST=
# LIWA: http client; empty token boots via UnconfiguredLiwa outside restricted envs.
LIWA_MODE=http
# Real API base includes /api (Swagger: https://chat.liwa.co/api/swagger/)
LIWA_BASE_URL=https://chat.liwa.co/api
LIWA_API_TOKEN=
# Account page_id for liwa.tenant_bindings (Coopfuturo 2026 Cta Comercial)
LIWA_ACCOUNT_ID=1656233
# Flow IDs discovered via GET /accounts/flows (Swagger: POST /contacts/{id}/send/{flow_id})
LIWA_DEFAULT_FLOW_ID=1782399915832
LIWA_FLOW_ID_B=1782486171458
# After voice.call.completed with positive tipify → auto-send LIWA flow (true by default).
# Set false to require Ops review approve before send.
POST_CALL_WHATSAPP_AUTO_SEND=true
# Advisor Conversaciones reply uses send/text by default. Set LIWA_BLOCK_TEXT=1 to soft-block.
# LIWA_BLOCK_TEXT=
LIWA_VIP_TAG=RENOVACION_VIP
# Outbound smoke: LIWA_SMOKE_PHONE=+57300... node scripts/autonomy/liwa-outbound-smoke.mjs
# Neutral Dialer v3 overlay (infra/docker-compose.dialer.yml)
# Build context is relative to infra/. Sibling checkout on Desktop: ../../dialer/Dialer
# Prebuilt: set DIALER_IMAGE and use --no-build.
DIALER_CONTEXT=../../dialer/Dialer
DIALER_IMAGE=
DIALER_HOST_PORT=18080
DIALER_APP_ENV=local
DIALER_DB_SSLMODE=disable
DIALER_POSTGRES_USER=dialer
DIALER_POSTGRES_PASSWORD=dialer-local-dev-password-24
DIALER_POSTGRES_DB=dialer
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASSWORD=replace-dialer-admin-password-39
AUTH_JWT_SECRET=replace-dialer-jwt-secret-at-least-32-chars
DEMO_API_KEY=replace-dialer-demo-api-key-000040
ML_MODEL_HMAC_KEY=replace-dialer-ml-hmac-key-32chars-min
NUMBER_ROTATION_MODE=static
ASR_CONTEXT=../dialer/companions/Asr-Api
AMD_CONTEXT=../dialer/companions/AMD
ASR_IMAGE=
AMD_IMAGE=
ASR_SERVICE_TOKEN=
ASR_ADMIN_TOKEN=
AMD_ENABLED=false
AMD_SERVICE_TOKEN=
# NOVA core CRM adapter (disabled by default; contract only for explicit local tests; live requires HTTPS + token)
CORE_MODE=disabled
CORE_BASE_URL=
CORE_API_TOKEN=
# documents-service object storage (MinIO defaults in compose)
DOCUMENTS_S3_BUCKET=hyperion-documents
DOCUMENTS_S3_ENDPOINT=http://minio:9000
DOCUMENTS_S3_ACCESS_KEY=minioadmin
DOCUMENTS_S3_SECRET_KEY=minioadmin
DOCUMENTS_S3_REGION=us-east-1
DOCUMENTS_S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
DOCUMENTS_STORAGE_DIR=/var/lib/hyperion/documents
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Local only — never commit real keys. Agents via:
#   node scripts/autonomy/elevenlabs-bootstrap-nova.mjs --write-env
# DDI still requires Twilio/SIP import into ElevenLabs before voice smoke.
ELEVENLABS_API_KEY=
# HMAC dedicado para callbacks; no reutilizar ELEVENLABS_API_KEY.
ELEVENLABS_WEBHOOK_HMAC_SECRET=
# Flujo A (Renovación) — also mirrored to DEMO_AGENT_ID by bootstrap.
ELEVENLABS_AGENT_ID=
# Flujo B (Reactivación)
ELEVENLABS_AGENT_ID_B=
DEMO_AGENT_ID=
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_STT_LANGUAGE=spa
ELEVENLABS_STT_TIMEOUT_MS=120000
ELEVENLABS_ZERO_RETENTION_MODE=true
LUMEN_AUDIO_TEMP_DIR=/tmp/lumen-audio
LUMEN_INSTANCE_ID=lumen-service-compose
LUMEN_AUDIO_CLEANUP_RETRY_MS=30000
LUMEN_AUDIO_CLEANUP_BATCH_SIZE=25
LUMEN_AUDIO_CLEANUP_LEASE_TTL_MS=1800000
LUMEN_AUDIO_CLEANUP_HEARTBEAT_MS=30000
SOFIA_WORKER_ENABLED=true
SOFIA_LEGACY_POLLING_ENABLED=false
DURABLE_EVENT_TRANSPORT=http
DURABLE_OUTBOX_ENABLED=true
DURABLE_HTTP_OUTBOX_ENABLED=true
# Proyección neutral Access→Channel. El Compose base la mantiene deshabilitada;
# el overlay JetStream la activa con identidades `access` y `channel` separadas.
ACCESS_TENANT_SNAPSHOT_TRANSPORT=disabled
ACCESS_TENANT_SNAPSHOT_HTTP_URL=http://whatsapp-channel-service:8089/internal/v1/events/access-tenant-snapshots,http://pulso-iris-service:8088/internal/v1/events/access-tenant-snapshots,http://agent-service:8083/internal/v1/events/access-tenant-snapshots,http://integration-service:8087/internal/v1/events/access-tenant-snapshots,http://knowledge-service:8085/internal/v1/events/access-tenant-snapshots
# Sólo un ensayo local explícito puede usar HTTP plano hacia hostnames privados
# allowlisted (whatsapp-channel-service, pulso-iris-service, agent-service).
# Staging/production deben mantenerlo en false y usar HTTPS o JetStream.
ACCESS_TENANT_SNAPSHOT_ALLOW_PRIVATE_HTTP=false
ACCESS_TENANT_SNAPSHOT_RECONCILE_LIMIT=100
ACCESS_TENANT_SNAPSHOT_RECONCILE_INTERVAL_MS=60000
# Provider-owned Access→LUMEN delivery. HTTP is the rollback transport; the
# JetStream overlay replaces it with the dedicated `access` publisher identity.
ACCESS_LUMEN_PROJECTION_TRANSPORT=http
ACCESS_LUMEN_BACKFILL_LIMIT=100
ACCESS_LUMEN_RECONCILE_INTERVAL_MS=60000
# Ventanas temporales de rollout. Mantener disabled fuera de una transición
# v1→v2 supervisada; cada consumidor v1 usa un durable separado.
CHANNEL_INBOUND_V1_COMPATIBILITY=disabled
PULSO_MESSAGE_V1_COMPATIBILITY=disabled
# Solo se requieren al usar infra/docker-compose.jetstream.yml.
NATS_URL=nats://nats:4222
# Siete secretos distintos, de al menos 24 caracteres. Deben empezar por letra y
# usar unicamente A-Z, a-z, 0-9, punto, guion, guion bajo o ~.
NATS_TOPOLOGY_PASSWORD=replace-topology-nats-secret-01
NATS_ACCESS_PASSWORD=replace-access-nats-secret-0001
NATS_CHANNEL_PASSWORD=replace-channel-nats-secret-002
NATS_PULSO_PASSWORD=replace-pulso-nats-secret-0003
NATS_SOFIA_PASSWORD=replace-sofia-nats-secret-00004
NATS_AUDIT_PASSWORD=replace-audit-nats-secret-000005
NATS_LUMEN_PASSWORD=replace-lumen-nats-secret-000006
WHATSAPP_WEB_TEST_ENABLED=false
WHATSAPP_TEST_ALLOWED_NUMBERS=
WHATSAPP_PHONE_HASH_KEY=replace-channel-phone-hash-key-00001
WHATSAPP_INBOUND_PERSIST_MAX_ATTEMPTS=3
WHATSAPP_INBOUND_PERSIST_RETRY_BASE_DELAY_MS=250
WHATSAPP_INBOUND_PERSIST_ATTEMPT_TIMEOUT_MS=10000
WHATSAPP_INBOUND_SPOOL_MAX_RECORDS=2000
WHATSAPP_INBOUND_SPOOL_MAX_BYTES=16777216
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace-with-real-admin-password
VITE_API_BASE_URL=https://api.hyperion.local
PULSO_IRIS_SERVICE_URL=http://pulso-iris-service:8088
LUMEN_SERVICE_URL=http://lumen-service:8090
API_GATEWAY_HOST_PORT=8080
# Consoles bind only to loopback by default; expose through a trusted reverse proxy.
HYPERION_CONSOLE_HOST_IP=127.0.0.1
PULSO_CONSOLE_HOST_PORT=3000
NOVA_BFF_HOST_PORT=8095
NOVA_CONSOLE_HOST_PORT=3010
LUMEN_CONSOLE_HOST_PORT=3002
PLATFORM_ADMIN_CONSOLE_HOST_PORT=3003
LEGACY_WEB_CONSOLE_HOST_PORT=3004
# Solo para el Compose/runbook legado de Contabo; las consolas federadas usan los puertos anteriores.
WEB_CONSOLE_HOST_PORT=13001
# Host port for CoopFuturo Next ops console (apps/coopfuturo-console). Contabo: 19001.
WEB_CONSOLE_NOVA_HOST_PORT=3011
# UUID opaco server-only para la consola específica CoopFuturo. Debe coincidir
# con un grant NOVA activo; no existe fallback a slug ni valor del navegador.
COOPFUTURO_TENANT_ID=
# Origen público canónico server-only de la app. Debe incluir esquema, hostname
# y puerto cuando aplique; las mutaciones sin Origin exacto se rechazan.
COOPFUTURO_PUBLIC_ORIGIN=https://coopfuturo.example.com
# El navegador usa siempre el adapter same-origin /pilot-core.
NEXT_PUBLIC_API_MODE=mock
