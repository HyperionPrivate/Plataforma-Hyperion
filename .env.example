# Coopfuturo platform — local orchestration only. Never commit real secrets.

COMPOSE_PROJECT_NAME=coopfuturo

# Postgres bootstrap (superuser solo para init; apps usan roles dedicados)
POSTGRES_USER=coopfuturo_admin
POSTGRES_PASSWORD=coopfuturo_admin_dev_only
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# App roles (CHANGE_ME antes de cualquier ambiente real)
PILOT_CORE_DB_USER=app_pilot_core
PILOT_CORE_DB_PASSWORD=CHANGE_ME_pilot_core
WHATSAPP_DB_USER=app_whatsapp
WHATSAPP_DB_PASSWORD=CHANGE_ME_whatsapp
DOCUMENTS_DB_USER=app_documents
DOCUMENTS_DB_PASSWORD=CHANGE_ME_documents
HANDOFF_DB_USER=app_handoff
HANDOFF_DB_PASSWORD=CHANGE_ME_handoff

REDIS_URL=redis://redis:6379/0

# Dialer externo — solo pilot-core / orchestration
DIALER_BASE_URL=http://host.docker.internal:8080
DIALER_API_TOKEN=

# OIDC (vacío en local = auth deshabilitada hasta Fase 5)
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=

# Traefik
TRAEFIK_HTTP_PORT=8088
TRAEFIK_DASHBOARD_ENABLED=false
TRAEFIK_DASHBOARD_PORT=8089

# LIWA WhatsApp — NO pegar tokens reales en git. Usar .local-secrets-tmp/ en local.
# LIWA_MODE=mock|real  (real requiere LIWA_API_TOKEN)
LIWA_BASE_URL=https://chat.liwa.co/api
LIWA_API_TOKEN=
LIWA_MODE=mock
