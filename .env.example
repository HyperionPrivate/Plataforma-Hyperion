# Orquestación local (Compose). Cada servicio tiene su propio .env.example.

COMPOSE_PROJECT_NAME=coopfuturo

POSTGRES_USER=coopfuturo
POSTGRES_PASSWORD=coopfuturo_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

# Dialer externo (solo orchestrator). No se build-ea en este monorepo.
DIALER_BASE_URL=http://host.docker.internal:8080
DIALER_API_TOKEN=

# Traefik
TRAEFIK_HTTP_PORT=8088
TRAEFIK_DASHBOARD_PORT=8089
