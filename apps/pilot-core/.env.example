APP_ENV=development
SERVICE_NAME=pilot-core
PORT=8201
DATABASE_URL=postgresql://app_pilot_core:CHANGE_ME@localhost:5432/db_pilot_core
REDIS_URL=redis://localhost:6379/0
AUTH_DISABLED=true
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
SERVICE_AUTH_SHARED_SECRET=
# Persistencia Ops (SQLite + docs). En Docker Compose: /data
PULSO_DATA_DIR=
# LIWA WhatsApp (valores reales solo en .local-secrets-tmp/)
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=
LIWA_MODE=mock
LIWA_BASE_URL=https://chat.liwa.co/api
LIWA_API_TOKEN=
LIWA_DEFAULT_FLOW_ID=1782399915832
LIWA_FLOW_ID_B=
LIWA_HANDOFF_TAG=RENOVACION_VIP
LIWA_HANDOFF_TAG_B=REACTIVACION_VIP
LIWA_WEBHOOK_SECRET=
LIWA_WEBHOOK_TENANT_ID=coopfuturo
# Documentos: mock | filesystem | minio
DOCUMENTS_STORAGE_BACKEND=filesystem
DOCUMENTS_LOCAL_ROOT=
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=coopfuturo-docs
# Core financiero (opcional)
CORE_BASE_URL=
CORE_API_TOKEN=
CORE_ASSOCIATE_PATH=/associates/{document_id}
