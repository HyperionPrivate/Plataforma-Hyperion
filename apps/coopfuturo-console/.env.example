NEXT_PUBLIC_API_MODE=mock
# Local (uvicorn directo):
# NEXT_PUBLIC_API_MODE=live
# NEXT_PUBLIC_PILOT_CORE_URL=http://127.0.0.1:8201
# NEXT_PUBLIC_REQUIRE_AUTH=false
# Docker Compose + Traefik (same-origin en el navegador):
# NEXT_PUBLIC_API_MODE=live
# NEXT_PUBLIC_PILOT_CORE_URL=/pilot-core
# NEXT_PUBLIC_REQUIRE_AUTH=true
# OIDC browser redirect (AUD2-005) — optional; paste-JWT remains for lab:
# NEXT_PUBLIC_OIDC_AUTHORIZE_URL=https://your-idp.example/realms/coopfuturo/protocol/openid-connect/auth?client_id=pulso-ops&response_type=token&scope=openid
