# Browser: the customer console always uses the same-origin /pilot-core adapter.
NEXT_PUBLIC_API_MODE=mock
NEXT_PUBLIC_REQUIRE_AUTH=false

# Required in live mode. This server-only opaque UUID binds the customer app to
# exactly one tenant grant; the adapter fails closed when it is absent or invalid.
COOPFUTURO_TENANT_ID=

# Required server-only canonical browser origin. Mutations without an exact
# Origin match are rejected; use HTTPS except for loopback development.
COOPFUTURO_PUBLIC_ORIGIN=https://coopfuturo.example.com

# Server-only NOVA BFF origin. Never expose this value through NEXT_PUBLIC_*.
# Local HTTPS development:
# NOVA_BFF_URL=http://127.0.0.1:8181
# NEXT_PUBLIC_API_MODE=live
# NEXT_PUBLIC_REQUIRE_AUTH=true

# Container network:
# NOVA_BFF_URL=http://nova-bff:8095
