{
  "name": "@hyperion/lumen-bff",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "pnpm --filter @hyperion/lumen-contracts build",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "pretest": "pnpm --filter @hyperion/lumen-contracts build",
    "test": "vitest run",
    "pretypecheck": "pnpm --filter @hyperion/lumen-contracts build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/rate-limit": "^11.1.0",
    "@hyperion/lumen-contracts": "1.1.0",
    "@hyperion/platform-contracts": "1.1.0",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
