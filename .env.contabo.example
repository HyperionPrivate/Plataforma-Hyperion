# Contabo containment profile — copy to server as .env.contabo (never commit real values).
# The application remains loopback-only until an HTTPS ingress is configured.
# OIDC issuer/audience/JWKS are mandatory: the stack will not start without them.
COMPOSE_PROJECT_NAME=pulso
TRAEFIK_HTTP_PORT=9088
TRAEFIK_HTTPS_PORT=9443
# AUD2-004: place tls.crt + tls.key under infra/certs/contabo/ then point routers to websecure.
# Until certs exist, HTTP loopback on :9088 remains the supported Contabo pilot path.
ENABLE_TLS=false
# Same-origin API path via Traefik (browser → http://127.0.0.1:9088/pilot-core/...).
PUBLIC_PILOT_CORE_URL=/pilot-core

POSTGRES_PASSWORD=CHANGE_ME_STRONG
REDIS_PASSWORD=CHANGE_ME_REDIS_STRONG
PILOT_CORE_DB_PASSWORD=CHANGE_ME_pilot_core
WHATSAPP_DB_PASSWORD=CHANGE_ME_whatsapp
DOCUMENTS_DB_PASSWORD=CHANGE_ME_documents
HANDOFF_DB_PASSWORD=CHANGE_ME_handoff

AUTH_DISABLED=false
APP_ENV=production

# Required for Contabo / production auth (fail-closed).
OIDC_ISSUER=https://your-idp.example/realms/coopfuturo
OIDC_AUDIENCE=pulso-ops
OIDC_JWKS_URL=https://your-idp.example/realms/coopfuturo/protocol/openid-connect/certs
CORS_ALLOWED_ORIGINS=http://127.0.0.1:9088,http://localhost:9088,https://127.0.0.1:9443
# Browser OIDC authorize URL (optional — enables redirect login in apps/web).
# NEXT_PUBLIC_OIDC_AUTHORIZE_URL=https://your-idp.example/realms/coopfuturo/protocol/openid-connect/auth?client_id=pulso-ops&response_type=token&scope=openid

DIALER_BASE_URL=
DIALER_DEFAULT_PHONE_NUMBER_ID=

LIWA_MODE=mock
LIWA_BASE_URL=https://chat.liwa.co/api
LIWA_API_TOKEN=
LIWA_DEFAULT_FLOW_ID=1782399915832
LIWA_FLOW_ID_B=
LIWA_WEBHOOK_SECRET=
LIWA_WEBHOOK_TENANT_ID=coopfuturo

ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=
POST_CALL_WHATSAPP_AUTO_SEND=false
