# Standalone PULSO cell only. Replace every placeholder before staging/production.
PULSO_NODE_ENV=development
PULSO_DEPLOYMENT_ENVIRONMENT=local
PULSO_AGENT_SERVICE_VERSION=0.2.0
PULSO_PROMPT_FLOW_SERVICE_VERSION=0.2.0
PULSO_KNOWLEDGE_SERVICE_VERSION=0.1.0
PULSO_INTEGRATION_SERVICE_VERSION=0.1.0
PULSO_IRIS_SERVICE_VERSION=0.1.0
PULSO_WHATSAPP_CHANNEL_SERVICE_VERSION=0.2.0
PULSO_BFF_VERSION=1.0.0

PULSO_POSTGRES_ADMIN_USER=hyperion_pulso_admin
PULSO_POSTGRES_ADMIN_PASSWORD=replace-pulso-admin-secret-0001
PULSO_POSTGRES_DB=hyperion_pulso
PULSO_MIGRATOR_DATABASE_PASSWORD=replace-pulso-migrator-secret-02
PULSO_DATABASE_PASSWORD=replace-pulso-runtime-secret-0003
SOFIA_DATABASE_PASSWORD=replace-sofia-runtime-secret-0004
KNOWLEDGE_DATABASE_PASSWORD=replace-knowledge-runtime-secret-05
INTEGRATION_DATABASE_PASSWORD=replace-integration-runtime-secret-6
CHANNEL_DATABASE_PASSWORD=replace-channel-runtime-secret-0007

PULSO_BFF_TO_ACCESS_TOKEN=replace-pulso-access-edge-00008
PULSO_BFF_TO_CORE_TOKEN=replace-pulso-core-edge-0000009
PULSO_BFF_TO_INTEGRATION_TOKEN=replace-pulso-integration-edge-10
PULSO_OPERATOR_ASSERTION_KEY=replace-pulso-operator-assert-011
PULSO_TO_SOFIA_TOKEN=replace-pulso-sofia-edge-000012
SOFIA_TO_PULSO_TOKEN=replace-sofia-pulso-edge-000013
SOFIA_TO_CHANNEL_TOKEN=replace-sofia-channel-edge-00014
SOFIA_TO_PROMPT_FLOW_TOKEN=replace-sofia-prompt-edge-000015
INTEGRATION_TO_CHANNEL_TOKEN=replace-integration-channel-edge-16
INTEGRATION_TO_SOFIA_TOKEN=replace-integration-sofia-edge-017
INTEGRATION_TO_PULSO_TOKEN=replace-integration-pulso-edge-018
PULSO_TO_CHANNEL_TOKEN=replace-pulso-channel-edge-000019
CHANNEL_TO_PULSO_TOKEN=replace-channel-pulso-edge-000020

# Audit and Access stay in the neutral platform plane. HTTPS is mandatory
# outside an explicitly local/CI private-JWKS setup.
PULSO_ACCESS_SERVICE_URL=https://access.example.invalid
PULSO_ACCESS_JWKS_URL=https://access.example.invalid/.well-known/jwks.json
PULSO_ACCESS_JWKS_ALLOW_PRIVATE_HTTP=false
PULSO_ACCESS_TOKEN_ISSUER=https://access.example.invalid
PULSO_AUDIT_SERVICE_URL=https://audit.example.invalid
PULSO_TO_AUDIT_TOKEN=replace-pulso-audit-edge-000021
SOFIA_TO_AUDIT_TOKEN=replace-sofia-audit-edge-0000022
CHANNEL_TO_AUDIT_TOKEN=replace-channel-audit-edge-000023

# Provider keys stay absent by default. The cell remains health-checkable, but
# AI generation and real WhatsApp connectivity remain unavailable.
PULSO_DEEPSEEK_API_KEY=
PULSO_DEEPSEEK_BASE_URL=https://api.deepseek.com
PULSO_DEEPSEEK_MODEL=deepseek-v4-flash
PULSO_WHATSAPP_WEB_TEST_ENABLED=false
PULSO_WHATSAPP_TEST_ALLOWED_NUMBERS=
PULSO_WHATSAPP_PHONE_HASH_KEY=replace-pulso-phone-hash-key-000024
PULSO_VERIFICATION_SIMULATOR_ENABLED=false
PULSO_SOFIA_WORKER_ENABLED=true

PULSO_DURABLE_OUTBOX_ENABLED=true
PULSO_DURABLE_HTTP_OUTBOX_ENABLED=true
PULSO_POSTGRES_HOST_PORT=55440
PULSO_BFF_HOST_PORT=8097
PULSO_CONSOLE_HOST_PORT=3000
