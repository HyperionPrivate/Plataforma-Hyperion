     else:
         agent_id = agent_id_a
         pool = ddi_pool_a or [ddi_id_a]
-    ddi_id = secrets.choice(pool) if len(pool) > 1 else pool[0]
+    ddi_id = _select_demo_ddi(pool, str(cfg.get("NUMBER_ROTATION_MODE", "static") or "static"))

     # ------------------------------------------------------------------
     # 1. Auth — constant-time compare to avoid timing leaks.
diff --git a/tests/unit/test_demo_ddi_selection.py b/tests/unit/test_demo_ddi_selection.py
new file mode 100644
--- /dev/null
+++ b/tests/unit/test_demo_ddi_selection.py
@@ -0,0 +1,17 @@
+from adapters.primary.api.routes.demo import _select_demo_ddi
+
+
+def test_static_mode_always_selects_primary_ddi() -> None:
+    pool = ["phnum_primary", "phnum_secondary", "phnum_tertiary"]
+
+    assert {_select_demo_ddi(pool, "static") for _ in range(20)} == {"phnum_primary"}
+
+
+def test_non_static_mode_returns_a_configured_pool_member() -> None:
+    pool = ["phnum_primary", "phnum_secondary"]
+
+    assert _select_demo_ddi(pool, "asr") in pool
+
+
+def test_empty_pool_is_fail_closed() -> None:
+    assert _select_demo_ddi([], "static") == ""
