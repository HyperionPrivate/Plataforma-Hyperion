--- a/adapters/primary/api/routes/demo.py
+++ b/adapters/primary/api/routes/demo.py
@@ -145,6 +145,21 @@ def _sha256_hex(s: str) -> str:
     return hashlib.sha256(s.encode("utf-8")).hexdigest()


+def _select_demo_ddi(pool: list[str], rotation_mode: str) -> str:
+    """Honor static rotation for one-shot demo calls.
+
+    The demo endpoint owns its A/B pools and therefore cannot delegate this
+    choice to the campaign rotation adapter. Static mode must always select
+    the configured primary (first) DDI; non-static modes retain pool rotation.
+    """
+
+    if not pool:
+        return ""
+    if str(rotation_mode or "").strip().lower() == "static":
+        return pool[0]
+    return secrets.choice(pool) if len(pool) > 1 else pool[0]
+
+
 def _client_ip(request: Request) -> str:
     """Return a direct peer or gateway-authenticated forwarded address."""
     return resolve_trusted_client_ip(request)
