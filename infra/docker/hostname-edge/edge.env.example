# Reserved local test domains. Resolve them to 127.0.0.1 with hosts/DNS or
# use curl --resolve; this file never provisions public DNS or certificates.
PLATFORM_ADMIN_HOST=admin.hyperion.test
NOVA_HOST=nova.hyperion.test
COOPFUTURO_HOST=coopfuturo.hyperion.test
LUMEN_HOST=lumen.hyperion.test
PULSO_HOST=pulso.hyperion.test

# The edge container must share a narrow ingress network with only these
# consoles/BFFs. No upstream may point to api-gateway.
PLATFORM_ADMIN_CONSOLE_UPSTREAM=http://platform-admin-console:8080
PLATFORM_ADMIN_BFF_UPSTREAM=http://platform-admin-bff:8098
NOVA_CONSOLE_UPSTREAM=http://nova-console:8080
NOVA_BFF_UPSTREAM=http://nova-bff:8095
COOPFUTURO_CONSOLE_UPSTREAM=http://coopfuturo-console:3000
LUMEN_CONSOLE_UPSTREAM=http://lumen-console:8080
LUMEN_BFF_UPSTREAM=http://lumen-bff:8096
PULSO_CONSOLE_UPSTREAM=http://pulso-console:8080
PULSO_BFF_UPSTREAM=http://pulso-bff:8097

# Set to https only when a trusted TLS terminator is the sole caller of this
# private HTTP listener. This is fixed configuration, never a client header.
EDGE_FORWARDED_PROTO=http

# Shared only by hostname-edge and nova-bff. Replace before starting either
# Compose project; keep at least 32 random bytes.
NOVA_PROVIDER_EDGE_TOKEN=replace-nova-provider-edge-token-000001

# Production must narrow this to the private CIDR (or /32) of the TLS
# terminator that overwrites X-Forwarded-For. Direct clients are never trusted.
EDGE_TRUSTED_PROXY_CIDR=127.0.0.1/32
