    access_log off;
    default_type application/json;
    return 200 '{"status":"ok","cell":"lumen","surface":"hostname-edge"}';
  }

  location = /api {
    return 404;
  }

  location /api/ {
    include /etc/nginx/snippets/browser-bff-proxy.conf;
  }

  location = / {
    include /etc/nginx/snippets/console-proxy.conf;
  }

  location ^~ /assets/ {
    include /etc/nginx/snippets/console-proxy.conf;
  }

  location ~ ^/lumen(?:/[^/]+)?/?$ {
    include /etc/nginx/snippets/console-proxy.conf;
  }

  location / {
    return 404;
  }
}

