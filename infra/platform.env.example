# Standalone Platform control plane only. Replace every placeholder before use.
PLATFORM_NODE_ENV=development
PLATFORM_DEPLOYMENT_ENVIRONMENT=local
PLATFORM_IDENTITY_SERVICE_VERSION=0.1.0
PLATFORM_TENANT_SERVICE_VERSION=0.1.0
PLATFORM_AUDIT_SERVICE_VERSION=0.1.0
PLATFORM_ADMIN_BFF_VERSION=1.0.0

PLATFORM_POSTGRES_ADMIN_USER=hyperion_platform_admin
PLATFORM_POSTGRES_ADMIN_PASSWORD=replace-platform-admin-db-secret-0001
ACCESS_POSTGRES_DB=hyperion_access
ACCESS_MIGRATOR_DATABASE_PASSWORD=replace-access-migrator-db-secret-002
IDENTITY_DATABASE_PASSWORD=replace-identity-runtime-db-secret-003
TENANT_DATABASE_PASSWORD=replace-tenant-runtime-db-secret-0004
AUDIT_POSTGRES_DB=hyperion_audit
AUDIT_MIGRATOR_DATABASE_PASSWORD=replace-audit-migrator-db-secret-0005
AUDIT_DATABASE_PASSWORD=replace-audit-runtime-db-secret-000006

PLATFORM_ADMIN_BFF_TO_ACCESS_TOKEN=replace-platform-admin-access-edge-007
PLATFORM_ADMIN_BFF_TO_IDENTITY_TOKEN=replace-platform-admin-identity-edge-008
PLATFORM_ADMIN_BFF_TO_TENANT_TOKEN=replace-platform-admin-tenant-edge-0009
PLATFORM_ADMIN_OPERATOR_ASSERTION_KEY=replace-platform-admin-assertion-key-10

# The private signing key is mounted only into Identity. This example path is a
# placeholder; generate an RSA key of at least 2048 bits outside the repository.
PLATFORM_ACCESS_TOKEN_PRIVATE_KEY_FILE=./secrets/access-token-private-key.pem
PLATFORM_ACCESS_TOKEN_ISSUER=https://access.hyperion.local
PLATFORM_ACCESS_TOKEN_KEY_ID=access-platform-current
PLATFORM_ACCESS_TOKEN_TTL_SECONDS=300
PLATFORM_ACCESS_JWKS_ALLOW_PRIVATE_HTTP=true

PLATFORM_INITIAL_ADMIN_EMAIL=
PLATFORM_INITIAL_ADMIN_PASSWORD=
PLATFORM_SESSION_TTL_HOURS=12

PLATFORM_SHUTDOWN_TIMEOUT_MS=65000
PLATFORM_SHUTDOWN_GRACE_PERIOD=75s
PLATFORM_TRUST_PROXY=false
PLATFORM_POSTGRES_HOST_PORT=55438
PLATFORM_ACCESS_HOST_PORT=8081
PLATFORM_AUDIT_HOST_PORT=8086
PLATFORM_ADMIN_BFF_HOST_PORT=8098
PLATFORM_ADMIN_CONSOLE_HOST_PORT=3003

PLATFORM_ACCESS_MIGRATIONS_IMAGE=hyperion/access-migrations:local
PLATFORM_AUDIT_MIGRATIONS_IMAGE=hyperion/audit-migrations:local
