# Standalone LUMEN cell only. Replace every placeholder before staging/production.
LUMEN_NODE_ENV=development
LUMEN_DEPLOYMENT_ENVIRONMENT=local
LUMEN_SERVICE_VERSION=1.0.0
LUMEN_BFF_VERSION=1.0.0

LUMEN_POSTGRES_ADMIN_USER=hyperion_lumen_admin
LUMEN_POSTGRES_ADMIN_PASSWORD=replace-lumen-admin-secret-0001
LUMEN_POSTGRES_DB=hyperion_lumen
LUMEN_MIGRATOR_DATABASE_PASSWORD=replace-lumen-migrator-secret-02
LUMEN_DATABASE_PASSWORD=replace-lumen-runtime-secret-0003

LUMEN_BFF_TO_ACCESS_TOKEN=replace-lumen-access-edge-00004
LUMEN_BFF_TO_LUMEN_TOKEN=replace-lumen-service-edge-0005
LUMEN_OPERATOR_ASSERTION_KEY=replace-lumen-operator-assert-006
ACCESS_TO_LUMEN_TOKEN=replace-access-lumen-events-0007
PULSO_TO_LUMEN_TOKEN=replace-pulso-lumen-events-0008

# Access and Audit remain external platform dependencies. HTTPS is mandatory
# outside an explicitly local/CI private-JWKS setup.
LUMEN_ACCESS_SERVICE_URL=https://access.example.invalid
LUMEN_ACCESS_JWKS_URL=https://access.example.invalid/.well-known/jwks.json
LUMEN_ACCESS_JWKS_ALLOW_PRIVATE_HTTP=false
LUMEN_ACCESS_TOKEN_ISSUER=https://access.example.invalid
LUMEN_TO_AUDIT_TOKEN=
LUMEN_AUDIT_SERVICE_URL=https://audit.example.invalid

# Provider keys are intentionally absent by default. The stack starts for
# contract/health acceptance but transcription/structuring stay unavailable.
LUMEN_ELEVENLABS_API_KEY=
LUMEN_ELEVENLABS_STT_MODEL=scribe_v2
LUMEN_ELEVENLABS_STT_LANGUAGE=spa
LUMEN_ELEVENLABS_STT_TIMEOUT_MS=120000
LUMEN_ELEVENLABS_ZERO_RETENTION_MODE=true
LUMEN_DEEPSEEK_API_KEY=
LUMEN_DEEPSEEK_BASE_URL=https://api.deepseek.com
LUMEN_DEEPSEEK_MODEL=deepseek-v4-flash

LUMEN_INSTANCE_ID=lumen-standalone-01
LUMEN_DURABLE_OUTBOX_ENABLED=true
LUMEN_DURABLE_HTTP_OUTBOX_ENABLED=true
LUMEN_POSTGRES_HOST_PORT=55439
LUMEN_BFF_HOST_PORT=8096
LUMEN_CONSOLE_HOST_PORT=3002
