# Standalone NOVA cell only. Replace every placeholder before staging/production.
NOVA_NODE_ENV=development
NOVA_DEPLOYMENT_ENVIRONMENT=local
NOVA_SERVICE_VERSION=1.0.0
NOVA_BFF_VERSION=1.0.0

NOVA_POSTGRES_ADMIN_USER=hyperion_nova_admin
NOVA_POSTGRES_ADMIN_PASSWORD=replace-nova-admin-secret-0001
NOVA_POSTGRES_DB=hyperion_nova
NOVA_MIGRATOR_DATABASE_PASSWORD=replace-nova-migrator-secret-002
NOVA_DATABASE_PASSWORD=replace-nova-runtime-secret-0003
VOICE_DATABASE_PASSWORD=replace-voice-runtime-secret-0004
LIWA_DATABASE_PASSWORD=replace-liwa-runtime-secret-00005
DOCUMENTS_DATABASE_PASSWORD=replace-documents-runtime-secret-6

NOVA_BFF_TO_ACCESS_TOKEN=replace-nova-access-edge-000007
NOVA_BFF_TO_NOVA_TOKEN=replace-nova-core-edge-0000008
NOVA_BFF_TO_VOICE_TOKEN=replace-nova-voice-edge-000009
NOVA_BFF_TO_LIWA_TOKEN=replace-nova-liwa-edge-0000010
NOVA_BFF_TO_DOCUMENTS_TOKEN=replace-nova-documents-edge-11
NOVA_OPERATOR_ASSERTION_KEY=replace-nova-operator-assert-0012
NOVA_PROVIDER_EDGE_TOKEN=replace-nova-provider-edge-token-000001
NOVA_TO_VOICE_TOKEN=replace-core-voice-edge-0000013
NOVA_TO_LIWA_TOKEN=replace-core-liwa-edge-00000014
NOVA_TO_DOCUMENTS_TOKEN=replace-core-documents-edge-015
VOICE_TO_NOVA_TOKEN=replace-voice-core-edge-0000016
LIWA_TO_NOVA_TOKEN=replace-liwa-core-edge-00000017
DOCUMENTS_TO_NOVA_TOKEN=replace-documents-core-edge-018

# El modo contract/local permite smoke sin proveedores. Staging/production
# fallan cerrado en los runtimes si faltan las credenciales externas.
NOVA_VOICE_MODE=contract
NOVA_DIALER_BASE_URL=
NOVA_DIALER_ADMIN_USER=
NOVA_DIALER_ADMIN_PASSWORD=
NOVA_VOICE_TO_DIALER_TOKEN=
NOVA_DIALER_WEBHOOK_HMAC_SECRET=
NOVA_ELEVENLABS_AGENT_ID=
NOVA_ELEVENLABS_API_KEY=
NOVA_ELEVENLABS_WEBHOOK_HMAC_SECRET=

NOVA_LIWA_MODE=contract
NOVA_LIWA_API_BASE_URL=https://chat.liwa.co/api
NOVA_LIWA_API_TOKEN=
NOVA_LIWA_WEBHOOK_SECRET=
NOVA_LIWA_ACCOUNT_ID=

NOVA_TO_AUDIT_TOKEN=replace-nova-audit-edge-0000019
VOICE_TO_AUDIT_TOKEN=replace-voice-audit-edge-000020
LIWA_TO_AUDIT_TOKEN=replace-liwa-audit-edge-0000021
DOCUMENTS_TO_AUDIT_TOKEN=replace-documents-audit-edge-022
NOVA_AUDIT_SERVICE_URL=https://audit.example.invalid

NOVA_ACCESS_SERVICE_URL=https://access.example.invalid
NOVA_ACCESS_JWKS_URL=https://access.example.invalid/.well-known/jwks.json
# Keep false for the standalone descriptor. This escape hatch gates private
# HTTP for both the Access service origin and JWKS. The local/CI acceptance
# overlay overrides it to true; the NOVA BFF rejects it outside local/CI.
NOVA_ACCESS_JWKS_ALLOW_PRIVATE_HTTP=false
NOVA_ACCESS_TOKEN_ISSUER=https://access.example.invalid

NOVA_MINIO_ROOT_USER=nova-minio-user-00000023
NOVA_MINIO_ROOT_PASSWORD=replace-nova-minio-secret-0024
NOVA_DOCUMENTS_S3_BUCKET=hyperion-nova-documents
NOVA_BFF_HOST_PORT=8095
NOVA_CONSOLE_HOST_PORT=3010
NOVA_COOPFUTURO_HOST_PORT=3011
# Required only when the customer-coopfuturo profile is enabled. Use the opaque
# tenant UUID provisioned by Access; no slug or browser-provided fallback exists.
COOPFUTURO_TENANT_ID=
# Canonical external origin used for exact mutation Origin validation.
COOPFUTURO_PUBLIC_ORIGIN=https://coopfuturo.example.com
